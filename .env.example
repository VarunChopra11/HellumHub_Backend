# ==============================================================================
# Hellum IoT Core Backend — Environment Configuration Template
# Copy to .env and fill in real values before starting the server.
# ==============================================================================

# Application
APP_NAME=iot-core-backend
ENVIRONMENT=production            # dev | staging | production
LOG_LEVEL=INFO

# ==============================================================================
# MongoDB
# ==============================================================================
MONGO_URI=mongodb://localhost:27017
MONGO_DB_NAME=hellum_iot
MONGO_MIN_POOL_SIZE=5
MONGO_MAX_POOL_SIZE=50
MONGO_SERVER_SELECTION_TIMEOUT_MS=3000
MONGO_CONNECT_TIMEOUT_MS=5000
MONGO_SOCKET_TIMEOUT_MS=10000

# GridFS — firmware binary storage
GRIDFS_BUCKET_NAME=firmware

# ==============================================================================
# MQTT Broker
# ==============================================================================
# Internal connection from FastAPI to Mosquitto (plain MQTT, no TLS needed
# for intra-container traffic). ESP32s connect externally on port 8883 (MQTTS).
MQTT_BROKER_HOST=mosquitto          # service name in docker-compose
MQTT_BROKER_PORT=1883

# ==============================================================================
# Google Sign-In (SINGLE client ID used for consumers AND admins)
# Obtain from: Google Cloud Console → APIs & Services → Credentials
# ==============================================================================
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com

# ==============================================================================
# Admin RBAC
# ==============================================================================
# This email always has root/Super Admin access (checked against Google token).
# No DB entry required for this address.
SUPER_ADMIN_EMAIL=founder@hellum.dev

# ==============================================================================
# OAuth 2.0 — Google Home Account Linking
# Register in Google Actions Console → Account Linking → OAuth
# ==============================================================================
OAUTH_CLIENT_ID=hellum-google-home-client
OAUTH_CLIENT_SECRET=change-me-use-strong-secret
# Comma-separated list of URIs Google is allowed to redirect back to
OAUTH_REDIRECT_URIS=https://oauth-redirect.googleusercontent.com/r/YOUR_PROJECT_ID
OAUTH_AUTH_CODE_TTL_SECONDS=600

# ==============================================================================
# Consumer JWT (Hellum-issued, NOT a Google token)
# Used after /api/v1/auth/google verifies the Google token and issues our own.
# Generate with: openssl rand -hex 32
# ==============================================================================
CONSUMER_JWT_SECRET=change-me-use-strong-secret
CONSUMER_JWT_ALGORITHM=HS256
CONSUMER_JWT_TTL_SECONDS=3600         # 1 hour
CONSUMER_REFRESH_TOKEN_TTL_SECONDS=2592000   # 30 days

# ==============================================================================
# MQTT Binding Token — Device Provisioning
# Token issued to consumer, passed via BLE to ESP32, sent over MQTT to claim
# the device. Short-lived for security.
# ==============================================================================
BINDING_TOKEN_TTL_SECONDS=600    # 10 minutes

# ==============================================================================
# OTA — signed firmware download URLs
# ==============================================================================
PUBLIC_BASE_URL=https://api.hellum.dev
SIGNED_URL_SECRET=change-me-use-strong-secret
SIGNED_URL_TTL_SECONDS=1800

# ==============================================================================
# Rate limiting & CORS
# ==============================================================================
CHECK_RATE_LIMIT=60/minute
# Comma-separated origins, e.g.: https://app.hellum.dev,https://admin.hellum.dev
CORS_ORIGINS=

APP_NAME=ota-backend
ENVIRONMENT=prod
LOG_LEVEL=INFO

# MongoDB Atlas
MONGO_URI=mongodb+srv://<user>:<password>@<cluster>/<db>?retryWrites=true&w=majority
MONGO_DB_NAME=ota
MONGO_MIN_POOL_SIZE=5
MONGO_MAX_POOL_SIZE=50
MONGO_SERVER_SELECTION_TIMEOUT_MS=3000
MONGO_CONNECT_TIMEOUT_MS=5000
MONGO_SOCKET_TIMEOUT_MS=10000

# GridFS bucket name
GRIDFS_BUCKET_NAME=firmware

# Admin auth (use API key and/or JWT)
ADMIN_API_KEY=replace-with-random-value
JWT_SECRET=
JWT_ALGORITHM=HS256
JWT_AUDIENCE=

# Public endpoint behavior
CHECK_RATE_LIMIT=60/minute
CORS_ORIGINS=[]
PUBLIC_BASE_URL=https://your-render-service.onrender.com
SIGNED_URL_SECRET=replace-with-random-signing-secret
SIGNED_URL_TTL_SECONDS=1800
